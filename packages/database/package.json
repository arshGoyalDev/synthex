{
  "name": "@synthex/database",
  "version": "0.0.1",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "bun --env-file=../../.env prisma generate",
    "migrate": "bun --env-file=../../.env prisma migrate dev",
    "migrate:deploy": "bun --env-file=../../.env prisma migrate deploy",
    "studio": "bun --env-file=../../.env prisma studio",
    "push": "bun --env-file=../../.env prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "ioredis": "^5.3.2",
    "minio": "^7.1.3"
  },
  "devDependencies": {
    "prisma": "^6.3.0",
    "typescript": "^5.3.0"
  }
}