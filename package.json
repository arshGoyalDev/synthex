{
  "name": "synthex",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:reset": "docker-compose down -v && docker-compose up -d",
    "db:logs": "docker-compose logs -f",
    "db:migrate": "cd packages/database && bunx prisma migrate dev",
    "db:migrate:prod": "cd packages/database && bunx prisma migrate deploy",
    "db:studio": "cd packages/database && bunx prisma studio",
    "db:generate": "cd packages/database && bunx prisma generate",
    "db:setup": "bun run db:up && sleep 5 && bun run db:generate && bun run db:migrate"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.13",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ]
}